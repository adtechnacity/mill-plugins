package build

import mill._, scalalib._, publish._
import mill.contrib.versionfile.VersionFileModule
import com.github.lolgab.mill.mima.*
import atn.mill.*

val millVersion = mill.util.BuildInfo.millVersion

object projectVersion extends VersionFileModule {
  def moduleDir = build.moduleDir
}

trait MillPluginModule extends ScalaModule with PublishModule with Mima {
  def scalaVersion         = "3.8.2"
  def publishVersion       = projectVersion.currentVersion().toString
  def mimaPreviousVersions = Seq("0.3.0")

  def pomSettings = PomSettings(
    description = artifactName(),
    organization = "com.adtechnacity",
    url = "https://github.com/adtechnacity/mill-plugins",
    licenses = Seq(License.`Apache-2.0`),
    versionControl = VersionControl.github("adtechnacity", "mill-plugins"),
    developers = Seq(Developer("adtechnacity", "Adtechnacity", "https://github.com/adtechnacity"))
  )

  def compileMvnDeps = super.compileMvnDeps() ++ Seq(mvn"com.lihaoyi::mill-libs:$millVersion")

  trait MillPluginTests extends ScalaTests {
    def mvnDeps       = Seq(
      mvn"com.lihaoyi::utest:0.9.5",
      mvn"com.lihaoyi::mill-testkit:$millVersion",
      mvn"com.lihaoyi::mill-libs:$millVersion",
      mvn"org.scalacheck::scalacheck:1.19.0"
    )
    def testFramework = "utest.runner.Framework"
  }

  trait MillPluginExampleTests extends ScalaTests {
    def pluginModules: Seq[PublishModule]

    def mvnDeps       = Seq(mvn"com.lihaoyi::utest:0.9.5", mvn"com.lihaoyi::mill-testkit:$millVersion")
    def testFramework = "utest.runner.Framework"

    def pluginArtifacts: T[Seq[(mill.scalalib.publish.Artifact, os.Path, os.Path)]] = Task {
      Task.traverse(pluginModules) { m =>
        Task.Anon {
          (m.artifactMetadata(), m.jar().path, m.pom().path)
        }
      }()
    }

    def localM2Repo: T[PathRef] = Task {
      import java.nio.file.{Files, StandardCopyOption}
      val repo = Task.dest / "m2repo"
      for ((art, jar, pom) <- pluginArtifacts()) {
        val base = repo / os.RelPath(art.group.replace('.', '/')) / art.id / art.version
        os.makeDir.all(base)
        Files.copy(jar.toNIO, (base / s"${art.id}-${art.version}.jar").toNIO, StandardCopyOption.REPLACE_EXISTING)
        Files.copy(pom.toNIO, (base / s"${art.id}-${art.version}.pom").toNIO, StandardCopyOption.REPLACE_EXISTING)
      }
      PathRef(repo)
    }

    def forkEnv = Task {
      val repo      = localM2Repo().path
      val existing  = Task.env.getOrElse("COURSIER_REPOSITORIES", "ivy2Local|central")
      Map(
        "MILL_EXECUTABLE_PATH"  -> (build.moduleDir / "mill").toString,
        "COURSIER_REPOSITORIES" -> s"${repo.toNIO.toUri.toASCIIString}|$existing",
        "PLUGIN_VERSION"        -> projectVersion.currentVersion().toString
      )
    }
  }
}

object core extends MillPluginModule {
  def artifactName = "mill-core_mill1"
  def mvnDeps      = Seq(mvn"com.lihaoyi::upickle:4.1.0", mvn"org.eclipse.jgit:org.eclipse.jgit:7.5.0.202512021534-r")
}

object stryker4s extends MillPluginModule {
  def artifactName = "mill-stryker4s_mill1"
  def moduleDeps   = Seq(core)
  def mvnDeps      = Seq(
    mvn"io.stryker-mutator::stryker4s-core:0.19.1",
    mvn"io.stryker-mutator::stryker4s-command-runner:0.19.1",
    mvn"co.fs2::fs2-core:3.12.2"
  )

  object test    extends MillPluginTests
  object example extends MillPluginExampleTests {
    def pluginModules = Seq(core, stryker4s)
  }

  override def mimaBinaryIssueFilters =
    super.mimaBinaryIssueFilters() ++ Seq(ProblemFilter.exclude[MissingTypesProblem]("atn.mill.Stryker4sReport"))

}

object scalafix extends MillPluginModule {
  def artifactName = "mill-scalafix_mill1"
  def mvnDeps      = Seq(
    mvn"com.goyeau::mill-scalafix_mill1:0.6.0",
    mvn"ch.epfl.scala:scalafix-interfaces:0.14.6"
  )

  object example extends MillPluginExampleTests {
    def pluginModules = Seq(scalafix)
  }
}

object docs extends MillPluginModule {
